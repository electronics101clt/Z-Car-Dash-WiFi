<?xml version="1.0" encoding="utf-8"?>
<!-- Compact Essentials Widget (2x2) - Speed + RPM + Status -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Connection Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/connection_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_disconnected"
            android:contentDescription="Status" />

        <TextView
            android:id="@+id/connection_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Disconnected"
            android:textColor="#f44336"
            android:textSize="9sp"
            android:singleLine="true" />

        <ImageView
            android:id="@+id/warning_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_warning"
            android:visibility="gone"
            android:contentDescription="Warning" />
    </LinearLayout>

    <!-- Speed Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_speed"
            android:contentDescription="Speed" />

        <TextView
            android:id="@+id/speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0"
            android:textColor="#00ff88"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="km/h"
            android:textColor="#666666"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- RPM Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_rpm"
            android:contentDescription="RPM" />

        <TextView
            android:id="@+id/rpm_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0"
            android:textColor="#ff9500"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="RPM"
            android:textColor="#666666"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Mini Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_fuel"
            android:contentDescription="Fuel" />
        <TextView
            android:id="@+id/fuel_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="75%"
            android:textColor="#ffeb3b"
            android:textSize="10sp" />

        <View
            android:layout_width="16dp"
            android:layout_height="1dp" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_coolant"
            android:contentDescription="Coolant" />
        <TextView
            android:id="@+id/coolant_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="90°"
            android:textColor="#00d9ff"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
