<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"/>

    <!-- WiFi Status Dashboard with Material Atmosphere -->
    <FrameLayout
        android:id="@+id/dashboardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Background Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/dashboard_background"
            android:scaleType="centerCrop"
            android:alpha="0.9"/>

        <!-- Dark Overlay for better text visibility -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#55000000"/>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Image - fills space above status card -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/dashboard_header"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp"/>

            <!-- Status Card with Glass Effect - Compact -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_background"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status Icon -->
                <TextView
                    android:id="@+id/statusIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"/>

                <!-- Network Name -->
                <TextView
                    android:id="@+id/networkName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Searching for ZS..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Status Message -->
                <TextView
                    android:id="@+id/statusMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking WiFi connection..."
                    android:textSize="12sp"
                    android:textColor="#E0E0E0"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- IP Address -->
                <TextView
                    android:id="@+id/ipAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#B0B0B0"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Refresh Button -->
                <Button
                    android:id="@+id/refreshButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Refresh"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4CAF50"/>

                <!-- WiFi Settings Button -->
                <Button
                    android:id="@+id/wifiSettingsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="WiFi Settings"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2196F3"/>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
