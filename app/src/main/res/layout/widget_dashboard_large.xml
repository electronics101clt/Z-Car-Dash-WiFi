<?xml version="1.0" encoding="utf-8"?>
<!-- Large Full Dashboard Widget (4x3) - Complete dashboard with all gauges -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ImageView
            android:id="@+id/connection_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_disconnected"
            android:contentDescription="Connection" />

        <TextView
            android:id="@+id/connection_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Tap to connect to ZS"
            android:textColor="#f44336"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/warning_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_warning"
            android:visibility="gone"
            android:contentDescription="Warning" />

        <TextView
            android:id="@+id/last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated: --:--:--"
            android:textColor="#666666"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Primary Gauges Row - Speed & RPM (Large) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal">

        <!-- Speed - Large -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/widget_background_small">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_speed"
                    android:contentDescription="Speed" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="SPEED"
                    android:textColor="#00d9ff"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00ff88"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="6dp"
            android:layout_height="match_parent" />

        <!-- RPM - Large -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/widget_background_small">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_rpm"
                    android:contentDescription="RPM" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="RPM"
                    android:textColor="#00d9ff"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/rpm_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ff9500"
                android:textSize="42sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <ProgressBar
                android:id="@+id/rpm_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="8000"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_rpm" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <!-- Secondary Gauges Row - Coolant, Fuel, Voltage, Oil -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Coolant -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/coolant_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_coolant"
                android:contentDescription="Coolant" />

            <TextView
                android:id="@+id/coolant_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90°"
                android:textColor="#00d9ff"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/coolant_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="130"
                android:progress="90"
                android:progressDrawable="@drawable/progress_bar_coolant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COOLANT"
                android:textColor="#555555"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Fuel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/fuel_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_fuel"
                android:contentDescription="Fuel" />

            <TextView
                android:id="@+id/fuel_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75%"
                android:textColor="#ffeb3b"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/fuel_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="75"
                android:progressDrawable="@drawable/progress_bar_fuel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FUEL"
                android:textColor="#555555"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Voltage -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/voltage_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_voltage"
                android:contentDescription="Voltage" />

            <TextView
                android:id="@+id/voltage_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14.2V"
                android:textColor="#4caf50"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/voltage_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="180"
                android:progress="142"
                android:progressDrawable="@drawable/progress_bar_voltage" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BATTERY"
                android:textColor="#555555"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Oil Temp -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/oil_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_oil"
                android:contentDescription="Oil" />

            <TextView
                android:id="@+id/oil_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95°"
                android:textColor="#ff5722"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/oil_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="150"
                android:progress="95"
                android:progressDrawable="@drawable/progress_bar_coolant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OIL"
                android:textColor="#555555"
                android:textSize="7sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Footer - Trip Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:paddingVertical="4dp"
        android:background="#11ffffff">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_trip"
            android:contentDescription="Trip" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Trip:"
            android:textColor="#666666"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/trip_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0.0 km"
            android:textColor="#9c27b0"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="24dp"
            android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avg:"
            android:textColor="#666666"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/avg_speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0 km/h"
            android:textColor="#00ff88"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="24dp"
            android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max:"
            android:textColor="#666666"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/max_speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0 km/h"
            android:textColor="#ff9500"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
