<?xml version="1.0" encoding="utf-8"?>
<!-- Medium Dashboard Widget (4x2) - Enhanced with progress bars and icons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Header Row - Connection Status + Time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/connection_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_disconnected"
            android:contentDescription="Connection" />

        <TextView
            android:id="@+id/connection_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Tap to connect"
            android:textColor="#f44336"
            android:textSize="9sp"
            android:singleLine="true" />

        <ImageView
            android:id="@+id/warning_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_warning"
            android:visibility="gone"
            android:contentDescription="Warning" />

        <TextView
            android:id="@+id/last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textColor="#666666"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Main Gauges Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Speed Gauge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_speed"
                android:contentDescription="Speed" />

            <TextView
                android:id="@+id/speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00ff88"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#666666"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- RPM Gauge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_rpm"
                android:contentDescription="RPM" />

            <TextView
                android:id="@+id/rpm_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ff9500"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/rpm_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:max="8000"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_rpm" />
        </LinearLayout>

        <!-- Coolant Gauge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/coolant_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coolant"
                android:contentDescription="Coolant" />

            <TextView
                android:id="@+id/coolant_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90"
                android:textColor="#00d9ff"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/coolant_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:max="130"
                android:progress="90"
                android:progressDrawable="@drawable/progress_bar_coolant" />
        </LinearLayout>

        <!-- Fuel Gauge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp">

            <ImageView
                android:id="@+id/fuel_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_fuel"
                android:contentDescription="Fuel" />

            <TextView
                android:id="@+id/fuel_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75"
                android:textColor="#ffeb3b"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/fuel_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="75"
                android:progressDrawable="@drawable/progress_bar_fuel" />
        </LinearLayout>

    </LinearLayout>

    <!-- Secondary Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp">

        <!-- Voltage -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_voltage"
                android:contentDescription="Voltage" />
            <TextView
                android:id="@+id/voltage_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="14.2V"
                android:textColor="#4caf50"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Oil Temp -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_oil"
                android:contentDescription="Oil" />
            <TextView
                android:id="@+id/oil_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="95°C"
                android:textColor="#ff5722"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Trip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_trip"
                android:contentDescription="Trip" />
            <TextView
                android:id="@+id/trip_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="0.0km"
                android:textColor="#9c27b0"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
