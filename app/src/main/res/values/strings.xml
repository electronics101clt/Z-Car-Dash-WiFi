<resources>
    <string name="app_name">Z Car Dash</string>
    <string name="accessibility_description">Allows the app to stop CarPlay and take over WiFi control. Required to release the hotspot when CarPlay is blocking WiFi.</string>

    <!-- Widget Descriptions -->
    <string name="widget_description">Shows live car dashboard data from ZS</string>
    <string name="widget_speed_description">Minimal speed display - just your current speed</string>
    <string name="widget_compact_description">Compact dashboard with speed, RPM, and essential stats</string>
    <string name="widget_strip_description">Horizontal strip showing all metrics in a row</string>
    <string name="widget_medium_description">Enhanced dashboard with gauges and progress bars</string>
    <string name="widget_large_description">Full dashboard with all gauges, trip data, and stats</string>
    <string name="widget_gauges_description">Visual gauge-focused display with progress indicators</string>
    <string name="widget_stack_description">Swipe through metrics one at a time</string>

